---
import { fileURLToPath } from "node:url";
import { getShaderFiles, getMusicFiles } from "../lib/fileUtils.ts";

// TODO: use https://github.com/patriciogonzalezvivo/glslCanvas

const shadersRoot = fileURLToPath(
  new URL("../../public/shaders", import.meta.url),
);
const musicRoot = fileURLToPath(new URL("../../public/music", import.meta.url));

let shaderFiles = [];
let musicFiles = [];
try {
  shaderFiles = (await getShaderFiles(shadersRoot)).sort();
} catch {
  shaderFiles = [];
}
try {
  musicFiles = await getMusicFiles(musicRoot);
} catch {
  musicFiles = [];
}

const baseUrl = import.meta.env.BASE_URL;
---

<script
  lang="ts"
  type="module"
  define:vars={{ shaderFiles, baseUrl, musicFiles }}
>
  // @ts-nocheck
  import {
    getAudioSystem,
    ensureAudioRunning,
    setupAudioToggle,
    setupFFTModeToggle,
    markAudioUnlocked,
  } from "../lib/audio.ts";
  import { setupShaderBox, renderAll } from "../lib/renderer.ts";

  const SHADER_FILES = shaderFiles;
  const MUSIC_FILES = musicFiles;
  const BASE_URL = baseUrl;
  const MUSIC_FILE = MUSIC_FILES[0] || null;

  const startTime = performance.now();
  const timings = {
    startTime,
    lastFrameTime: { value: startTime },
    musicFile: MUSIC_FILE,
  };

  async function main() {
    const container = document.getElementById("shader-grid");
    const emptyState = document.getElementById("empty-state");

    if (!SHADER_FILES.length) {
      if (emptyState) emptyState.hidden = false;
      return;
    }

    if (emptyState) emptyState.hidden = true;
    let audioSystem = null;
    try {
      audioSystem = await getAudioSystem(`${BASE_URL}${MUSIC_FILE}`);
    } catch {
      audioSystem = null;
    }
    setupFFTModeToggle();
    setupAudioToggle(audioSystem, MUSIC_FILE);

    const instances = await Promise.all(
      SHADER_FILES.map((file) => setupShaderBox(file, container, BASE_URL)),
    );
    requestAnimationFrame((now) =>
      renderAll(instances, now, audioSystem, timings),
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", main);
  } else {
    main();
  }
</script>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Live Shaders Grid</title>
  </head>
  <body>
    <header>
      <h1>GLSL Boxes (Bonzomatic + Shadertoy)</h1>
      <div class="sub">
        Each card compiles and runs a fragment shader with Bonzomatic and
        Shadertoy compatibility uniforms.
      </div>
      <div id="audio-track" class="audio-track"></div>
      <pre id="audio-debug" class="audio-debug"></pre>
      <button id="fft-mode-toggle" class="audio-toggle" type="button">
        FFT mode
      </button>
      <button id="audio-toggle" class="audio-toggle" type="button">
        Unmute music
      </button>
    </header>
    <main>
      <p id="empty-state" class="empty-state" hidden>
        No shaders found under <strong>public/shaders</strong>.
      </p>
      <section id="shader-grid" class="grid"></section>
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      sans-serif;
    background: #0f1115;
    color: #dce1ea;
  }
  header {
    padding: 16px 20px;
    border-bottom: 1px solid #222835;
  }
  h1 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }
  .sub {
    margin-top: 6px;
    font-size: 0.85rem;
    color: #98a3b8;
  }
  .audio-toggle {
    margin-top: 10px;
    border: 1px solid #334158;
    border-radius: 8px;
    background: #1c2533;
    color: #dce1ea;
    padding: 6px 10px;
    font-size: 0.82rem;
    cursor: pointer;
  }
  .audio-toggle:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
  .audio-track {
    margin-top: 8px;
    font-size: 0.76rem;
    color: #7f8ca3;
  }
  .audio-debug {
    margin: 8px 0 0;
    padding: 8px 10px;
    border: 1px solid #2a3548;
    border-radius: 8px;
    background: #121925;
    color: #9fb0cb;
    font-size: 0.71rem;
    line-height: 1.35;
    white-space: pre-wrap;
    max-width: 600px;
  }
  main {
    padding: 16px;
  }
  .empty-state {
    margin: 0 0 12px;
    padding: 10px 12px;
    border: 1px solid #3f1b20;
    border-radius: 8px;
    background: #23151a;
    color: #ffb4be;
    font-size: 0.86rem;
  }
  .grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }
  .card {
    border: 1px solid #222835;
    border-radius: 10px;
    overflow: hidden;
    background: #151a22;
  }
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 12px;
    border-bottom: 1px solid #222835;
  }
  .name {
    font-size: 0.86rem;
    color: #c7d0e0;
  }
  .status {
    font-size: 0.78rem;
    padding: 2px 6px;
    border-radius: 999px;
  }
  .ok {
    background: #183420;
    color: #7fe29c;
  }
  .err {
    background: #3f1b20;
    color: #ff9ca8;
  }
  canvas {
    width: 100%;
    display: block;
    background: black;
    aspect-ratio: 16 / 9;
  }
  .log {
    margin: 0;
    padding: 10px 12px;
    border-top: 1px solid #222835;
    font-size: 0.74rem;
    line-height: 1.35;
    color: #ffb4be;
    white-space: pre-wrap;
    min-height: 40px;
  }
  .log.ok-log {
    color: #8fe3a8;
  }
</style>
