---
// @ts-nocheck
import { readdir } from "node:fs/promises";
import { join } from "node:path";
import { fileURLToPath } from "node:url";
import BonzomaticPlayer from "../lib/components/BonzomaticPlayer.astro";

// filesystem locations are always relative to the project, not the URL base
const shadersRoot = fileURLToPath(
  new URL("../../public/shaders", import.meta.url),
);
const musicRoot = fileURLToPath(new URL("../../public/music", import.meta.url));

async function collectShaderFiles(directory, prefix = "") {
  const entries = await readdir(directory, { withFileTypes: true });
  const files = [];

  for (const entry of entries) {
    const nextPrefix = prefix ? `${prefix}/${entry.name}` : entry.name;
    const fullPath = join(directory, entry.name);

    if (entry.isDirectory()) {
      files.push(...(await collectShaderFiles(fullPath, nextPrefix)));
      continue;
    }

    if (entry.isFile()) {
      files.push(nextPrefix.replace(/\\/g, "/"));
    }
  }

  return files;
}

let shaderFiles = [];
try {
  shaderFiles = (await collectShaderFiles(shadersRoot)).sort();
} catch {
  shaderFiles = [];
}

let musicFiles = [];
try {
  const entries = await readdir(musicRoot, { withFileTypes: true });
  musicFiles = entries
    .filter(
      (entry) => entry.isFile() && entry.name.toLowerCase().endsWith(".mp3"),
    )
    .map((entry) => `music/${entry.name}`)
    .sort();
} catch {
  musicFiles = [];
}

const rawBaseUrl = import.meta.env.BASE_URL || Astro.base || "/";
const baseUrl = rawBaseUrl.endsWith("/") ? rawBaseUrl : rawBaseUrl + "/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={baseUrl + "favicon.svg"} />
    <link rel="icon" href={baseUrl + "favicon.ico"} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Brage's shaders</title>
  </head>
  <body>
    <header>
      <h1>Brage's fragment shaders</h1>
      <p class="sub">
        This is a small page showing the fragment shaders I have written,
        mostly as part of live shader coding using the program
        <a href="https://github.com/TheNuSan/Bonzomatic">Bonzomatic</a>. The
        shaders live under <code>public/shaders</code> and are rendered inside
        this page with a simple WebGL2 player component.
      </p>
    </header>
    <main>
      {shaderFiles.length === 0 ? (
        <p class="empty-state">
          No shaders found under <strong>public/shaders</strong>.
          {baseUrl && (
            <>
              {' '}(served at <strong>{baseUrl}shaders</strong>)
            </>
          )}
        </p>
      ) : (
        <div class="grid">
          {shaderFiles.map((f) => (
            <article class="card">
              <h2>{f}</h2>
              <BonzomaticPlayer src={`${baseUrl}shaders/${f}`} />
            </article>
          ))}
        </div>
      )}
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family:
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      sans-serif;
    background: #0f1115;
    color: #dce1ea;
  }
  header {
    padding: 16px 20px;
    border-bottom: 1px solid #222835;
  }
  h1 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }
  .sub {
    margin-top: 6px;
    font-size: 0.85rem;
    color: #98a3b8;
  }
  .grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }
  .card {
    border: 1px solid #222835;
    border-radius: 10px;
    overflow: hidden;
    background: #151a22;
  }
  .card h2 {
    margin: 0;
    padding: 10px 12px;
    font-size: 0.86rem;
    color: #c7d0e0;
    border-bottom: 1px solid #222835;
  }
  canvas {
    width: 100%;
    display: block;
    background: black;
    aspect-ratio: 16 / 9;
  }
  .empty-state {
    margin: 0 0 12px;
    padding: 10px 12px;
    border: 1px solid #3f1b20;
    border-radius: 8px;
    background: #23151a;
    color: #ffb4be;
    font-size: 0.86rem;
  }
</style>
